{% comment %}
  Collection page with customer-tag-aware product filtering.
  - Customers tagged 'wholesale' see ALL products (including wholesale-only)
  - Regular customers / guests see only products NOT tagged 'wholesale-only'
{% endcomment %}

<h1>{{ collection.title }}</h1>

{% comment %} Check if logged-in customer has 'wholesale' tag {% endcomment %}
{% assign is_wholesale = false %}
{% if customer %}
  {% for tag in customer.tags %}
    {% if tag == 'wholesale' %}
      {% assign is_wholesale = true %}
    {% endif %}
  {% endfor %}
{% endif %}

<div class="collection-products">
  {% comment %} 
    Step 1: Determine if the logged-in customer is a wholesale customer 
  {% endcomment %}
  {% assign is_wholesale_customer = false %}
  {% if customer %}
    {% if customer.tags contains 'wholesale' %}
      {% assign is_wholesale_customer = true %}
    {% endif %}
  {% endif %}

  {% paginate collection.products by 20 %}
    {% for product in collection.products %}

      {% comment %} Step 2: Check if this product is restricted to wholesale-only {% endcomment %}
      {% assign is_wholesale_only_product = false %}
      {% if product.tags contains 'wholesale-only' %}
        {% assign is_wholesale_only_product = true %}
      {% endif %}

      {% comment %} 
        Step 3: Visibility Logic
        Show if: (Product is NOT wholesale) OR (Product IS wholesale AND Customer IS wholesale)
      {% endcomment %}
      {% if is_wholesale_only_product == false or is_wholesale_customer == true %}
        <div class="collection-product">
          {% if product.featured_image %}
            {% render 'image',
              class: 'collection-product__image',
              image: product.featured_image,
              url: product.url,
              width: 400,
              height: 400,
              crop: 'center'
            %}
          {% endif %}
          
          <div class="collection-product__content">
            {% comment %} 
              Using escape and link_to properly as per your original structure 
            {% endcomment %}
            <p>{{ product.title | escape | link_to: product.url }}</p>
            <p>{{ product.price | money }}</p>
          </div>
        </div>
      {% endif %}

    {% endfor %}

    <div class="pagination">
      {{ paginate | default_pagination }}
    </div>
  {% endpaginate %}
</div>

{% stylesheet %}
  .collection-products {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); /* Grid size adjusted for better UI */
    gap: 20px;
    padding: 20px;
  }
  .collection-product {
    border: 1px solid #eee;
    padding: 10px;
    text-align: center;
  }
  .collection-product__image {
    max-width: 100%;
    height: auto;
  }
  .pagination {
    grid-column: 1 / -1;
    text-align: center;
    margin-top: 30px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Grid",
  "settings": [],
  "presets": [
    {
      "name": "Default Collection"
    }
  ]
}
{% endschema %}