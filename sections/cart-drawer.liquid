<script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>

<cart-drawer id="cart-drawer">
  <div class="cart-drawer-overlay" id="cart-overlay"></div>
  <div class="cart-drawer-content">
    <div class="cart-drawer-header">
      <h3>Your Cart</h3>
      <button id="close-cart">✕</button>
    </div>
    <div id="cart-items"></div>
    <div class="cart-drawer-footer">
      <div class="cart-total">
        Total: <span id="cart-total-price">$0.00</span>
      </div>
      <a href="/checkout" class="btn-checkout">Proceed to Checkout</a>
    </div>
  </div>
</cart-drawer>

<style>
cart-drawer {
  position: fixed;
  top: 0;
  right: -400px;
  width: 400px;
  height: 100%;
  z-index: 9999;
  transition: right 0.3s ease;
}
cart-drawer.open { right: 0; }
.cart-drawer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: none;
  z-index: -1;
}
cart-drawer.open .cart-drawer-overlay { display: block; }
.cart-drawer-content {
  position: absolute;
  right: 0;
  width: 100%;
  height: 100%;
  background: #fff;
  display: flex;
  flex-direction: column;
  padding: 20px;
  overflow-y: auto;
}
.cart-drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  border-bottom: 1px solid #ddd;
  padding-bottom: 10px;
}
.cart-drawer-header h3 { margin: 0; }
#close-cart { background: none; border: none; font-size: 20px; cursor: pointer; }
.cart-item { border: 1px solid #ddd; border-radius: 8px; padding: 15px; margin-bottom: 15px; }
.cart-item h4 { margin: 0 0 10px; }
.cart-item-properties { font-size: 13px; color: #666; }
.cart-item-properties p { margin: 4px 0; border-bottom: 1px solid #f0f0f0; padding-bottom: 4px; }
.cart-drawer-footer { margin-top: auto; border-top: 1px solid #ddd; padding-top: 15px; }
.cart-total { font-size: 18px; font-weight: bold; margin-bottom: 15px; }
.btn-checkout { display: block; background: #000; color: #fff; text-align: center; padding: 15px; border-radius: 4px; text-decoration: none; font-size: 16px; }
</style>

{% schema %}
{
  "name": "Cart Drawer",
  "presets": [
    {
      "name": "Cart Drawer"
    }
  ]
}
{% endschema %}