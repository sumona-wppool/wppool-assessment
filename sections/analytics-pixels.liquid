<!-- Pinterest Tag -->
{% if section.settings.pinterest_tag_id != blank %}
<script>
!function(e){if(!window.pintrk){window.pintrk = function () {
window.pintrk.queue.push(Array.prototype.slice.call(arguments))};var
  n=window.pintrk;n.queue=[],n.version="3.0";var
  t=document.createElement("script");t.async=!0,t.src=e;var
  r=document.getElementsByTagName("script")[0];
  r.parentNode.insertBefore(t,r)}}("https://s.pinimg.com/ct/core.js");
pintrk('load', '{{ section.settings.pinterest_tag_id }}');
pintrk('page');
</script>
{% endif %}

<!-- Google Ads -->
{% if section.settings.google_ads_id != blank %}
<script async src="https://www.googletagmanager.com/gtag/js?id={{ section.settings.google_ads_id }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ section.settings.google_ads_id }}');
</script>
{% endif %}

{% endif %}

{% schema %}
{
  "name": "Analytics Pixels",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_analytics",
      "label": "Enable Analytics",
      "default": true
    },
    {
      "type": "text",
      "id": "ga4_id",
      "label": "Google Analytics 4 ID",
      "placeholder": "G-XXXXXXXXXX"
    },
    {
      "type": "text",
      "id": "fb_pixel_id",
      "label": "Facebook Pixel ID",
      "placeholder": "XXXXXXXXXXXXXXXXXX"
    },
    {
      "type": "text",
      "id": "tiktok_pixel_id",
      "label": "TikTok Pixel ID",
      "placeholder": "XXXXXXXXXXXXXXXXXX"
    },
    {
      "type": "text",
      "id": "pinterest_tag_id",
      "label": "Pinterest Tag ID",
      "placeholder": "XXXXXXXXXXXXXXXXXX"
    },
    {
      "type": "text",
      "id": "google_ads_id",
      "label": "Google Ads ID",
      "placeholder": "AW-XXXXXXXXXX"
    }
  ],
  "presets": [
    {
      "name": "Analytics Pixels"
    }
  ]
}
{% endschema %}