<script src="{{ 'product-configurator.js' | asset_url }}" defer></script>

{%- if product.tags contains 'unavailable' -%}
  <div class="unavailable-msg">
    <p>Currently Unavailable</p>
  </div>
{%- else -%}

  {%- if product.metafields.custom.vimeo_id != blank -%}
    <div class="vimeo-wrapper">
      <iframe src="https://player.vimeo.com/video/{{ product.metafields.custom.vimeo_id }}" width="100%" height="400" frameborder="0" allowfullscreen></iframe>
    </div>
  {%- endif -%}

  <div class="ship-date">
    <p>
      <strong>Estimated Ship Date:</strong>
      {% if section.settings.quick_ship %}
        Ships in {{ section.settings.quick_ship_days }} business days
      {% else %}
        Ships in {{ section.settings.standard_lead_time }} weeks
      {% endif %}
    </p>
  </div>

  <product-configurator
    data-base-price="{{ product.price | divided_by: 100.0 }}"
    data-variant-id="{{ product.variants.first.id }}">

    <div class="price-display">
      <h2>Total Price: $<span id="total-price">{{ product.price | divided_by: 100.0 | round: 2 }}</span></h2>
    </div>

    <div class="steps-progress">
      <div class="step-indicator active" data-step="1">1. Model</div>
      <div class="step-indicator" data-step="2">2. Ventilation</div>
      <div class="step-indicator" data-step="3">3. Molding</div>
      <div class="step-indicator" data-step="4">4. Size Modification</div>
      <div class="step-indicator" data-step="5">5. Order Options</div>
    </div>

    <div class="step-panel active" data-step="1">
      <h3>Step 1: Model</h3>
      <div class="field-group">
        <label>Color Options</label>
        <select name="Color Options" id="color-options">
          <option value="">Select Color Option</option>
          <option value="Standard Color">Standard Color</option>
          <option value="Paint Match">Paint Match (+$150)</option>
          <option value="Sherwin-Williams Match">Sherwin-Williams Match (+$200)</option>
        </select>
      </div>
      <div class="field-group" id="paint-finish-group" style="display:none">
        <label>Color Finish</label>
        <select name="Color Finish">
          <option value="">Select Finish</option>
          <option value="Matte White">Matte White</option>
          <option value="Matte Black">Matte Black</option>
          <option value="Brushed Nickel">Brushed Nickel</option>
          <option value="Antique Brass">Antique Brass</option>
        </select>
      </div>
      <div class="field-group" id="color-match-group" style="display:none">
        <label>Color Match Selection</label>
        <input type="text" name="Color Match Selection" placeholder="Enter your color name">
      </div>
      <div class="field-group" id="sw-code-group" style="display:none">
        <label>Sherwin-Williams Color Code</label>
        <input type="text" name="SW Color Code" placeholder="e.g. SW 7015">
      </div>
      <div class="field-group">
        <label>Size</label>
        <select name="Size">
          <option value="">Select Size</option>
          <option value="30 inch">30 inch</option>
          <option value="36 inch">36 inch</option>
          <option value="42 inch">42 inch</option>
          <option value="48 inch">48 inch</option>
        </select>
      </div>
      <button type="button" class="btn-next" data-next="2">Next: Ventilation →</button>
    </div>

    <div class="step-panel" data-step="2" style="display:none">
      <h3>Step 2: Ventilation</h3>
      <div class="field-group">
        <label>Ventilation Brand</label>
        <select name="Ventilation Options" id="ventilation-brand">
          <option value="">Select Brand</option>
          <option value="Broan">Broan</option>
          <option value="ZLine">ZLine</option>
          <option value="Vent-A-Hood">Vent-A-Hood</option>
          <option value="TradeWinds">TradeWinds</option>
          <option value="Hauslane">Hauslane</option>
          <option value="Non-Ducted">Non-Ducted Kit</option>
        </select>
      </div>
      <div class="field-group" id="broan-cfm" style="display:none">
        <label>Broan CFM</label>
        <select name="Broan CFM">
          <option value="">Select CFM</option>
          <option value="Broan 160 CFM">160 CFM</option>
          <option value="Broan 220 CFM" data-price="50">220 CFM (+$50)</option>
          <option value="Broan 300 CFM" data-price="100">300 CFM (+$100)</option>
        </select>
      </div>
      <div class="field-group" id="zline-cfm" style="display:none">
        <label>ZLine CFM</label>
        <select name="ZLine CFM">
          <option value="">Select CFM</option>
          <option value="ZLine 400 CFM">400 CFM</option>
          <option value="ZLine 700 CFM" data-price="80">700 CFM (+$80)</option>
        </select>
      </div>
      <div class="field-group" id="ventahood-cfm" style="display:none">
        <label>Vent-A-Hood CFM</label>
        <select name="Vent-A-Hood CFM">
          <option value="">Select CFM</option>
          <option value="VAH 300 CFM">300 CFM</option>
          <option value="VAH 600 CFM" data-price="120">600 CFM (+$120)</option>
        </select>
      </div>
      <div class="field-group" id="tradewinds-cfm" style="display:none">
        <label>TradeWinds CFM</label>
        <select name="TradeWinds CFM">
          <option value="">Select CFM</option>
          <option value="TW 350 CFM">350 CFM</option>
          <option value="TW 600 CFM" data-price="90">600 CFM (+$90)</option>
        </select>
      </div>
      <div class="field-group" id="hauslane-cfm" style="display:none">
        <label>Hauslane CFM</label>
        <select name="Hauslane CFM">
          <option value="">Select CFM</option>
          <option value="HL 450 CFM">450 CFM</option>
          <option value="HL 900 CFM" data-price="110">900 CFM (+$110)</option>
        </select>
      </div>
      <div class="field-group">
        <label>Add Recirculating Vent</label>
        <select name="Recirculating Vent">
          <option value="No">No</option>
          <option value="Yes" data-price="75">Yes (+$75)</option>
        </select>
      </div>
      <button type="button" class="btn-prev" data-prev="1">← Back</button>
      <button type="button" class="btn-next" data-next="3">Next: Molding →</button>
    </div>

    <div class="step-panel" data-step="3" style="display:none">
      <h3>Step 3: Molding</h3>
      <div class="field-group">
        <label>Trim Options</label>
        <select name="Trim Options">
          <option value="No Trim">No Trim</option>
          <option value="Standard Trim" data-price="50">Standard Trim (+$50)</option>
          <option value="Premium Trim" data-price="100">Premium Trim (+$100)</option>
        </select>
      </div>
      <div class="field-group">
        <label>Trim Style</label>
        <select name="Trim Style">
          <option value="Painted">Painted</option>
          <option value="Stained" data-price="30">Stained (+$30)</option>
        </select>
      </div>
      <div class="field-group">
        <label>Crown Molding</label>
        <select name="Crown Molding">
          <option value="No Crown Molding">No Crown Molding</option>
          <option value="Crown Molding Installed" data-price="260">Crown Molding Installed (+$260)</option>
        </select>
      </div>
      <button type="button" class="btn-prev" data-prev="2">← Back</button>
      <button type="button" class="btn-next" data-next="4">Next: Size Modification →</button>
    </div>

    <div class="step-panel" data-step="4" style="display:none">
      <h3>Step 4: Size Modification</h3>
      <div class="field-group">
        <label>Increase Depth</label>
        <select name="Increase Depth">
          <option value="No">No</option>
          <option value="Yes" data-price="120">Yes (+$120)</option>
        </select>
      </div>
      <div class="field-group">
        <label>Reduce Height</label>
        <select name="Reduce Height">
          <option value="No">No</option>
          <option value="Yes" data-price="165">Yes (+$165)</option>
        </select>
      </div>
      <div class="field-group">
        <label>Extend Your Chimney</label>
        <select name="Extend Chimney">
          <option value="No">No</option>
          <option value="Yes" data-price="95">Yes (+$95)</option>
        </select>
      </div>
      <div class="field-group">
        <label>Add Solid Bottom</label>
        <select name="Add Solid Bottom">
          <option value="No">No</option>
          <option value="Yes" data-price="85">Yes (+$85)</option>
        </select>
      </div>
      <button type="button" class="btn-prev" data-prev="3">← Back</button>
      <button type="button" class="btn-next" data-next="5">Next: Order Options →</button>
    </div>

    <div class="step-panel" data-step="5" style="display:none">
      <h3>Step 5: Order Options</h3>
      <div class="field-group">
        <label>Rush Manufacturing</label>
        <select name="Rush Manufacturing">
          <option value="No">No - Standard Lead Time</option>
          <option value="Yes" data-price="299">Yes - Rush (+$299)</option>
        </select>
      </div>
      <div class="final-summary">
        <h3>Your Configuration Summary</h3>
        <div id="full-summary"></div>
        <h3>Total Price: $<span id="final-price">0</span></h3>
      </div>
      <button type="button" class="btn-prev" data-prev="4">← Back</button>
      <button type="button" id="add-to-cart-btn" class="btn-add-cart">Add to Cart</button>
    </div>

  </product-configurator>

{%- endif -%}

<style>
.unavailable-msg { background: #f8d7da; color: #721c24; padding: 20px; border-radius: 8px; text-align: center; font-size: 1.2em; font-weight: bold; }
.ship-date { background: #e8f5e9; padding: 12px; border-radius: 6px; margin-bottom: 16px; }
.vimeo-wrapper { margin-bottom: 20px; }
product-configurator { display: block; max-width: 800px; margin: 0 auto; padding: 20px; font-family: sans-serif; }
.price-display { background: #000; color: #fff; padding: 16px; border-radius: 8px; margin-bottom: 20px; text-align: center; }
.price-display h2 { margin: 0; }
.steps-progress { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
.step-indicator { padding: 8px 12px; background: #e0e0e0; border-radius: 20px; font-size: 13px; }
.step-indicator.active { background: #000; color: #fff; }
.step-indicator.completed { background: #28a745; color: #fff; }
.step-panel { background: #f9f9f9; border: 1px solid #ddd; border-radius: 8px; padding: 24px; margin-bottom: 20px; }
.field-group { margin-bottom: 16px; }
.field-group label { display: block; font-weight: bold; margin-bottom: 6px; }
.field-group select, .field-group input { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 15px; }
.btn-next, .btn-prev, .btn-add-cart { padding: 12px 24px; border: none; border-radius: 4px; cursor: pointer; font-size: 15px; margin-right: 10px; margin-top: 10px; }
.btn-next { background: #000; color: #fff; }
.btn-prev { background: #e0e0e0; color: #000; }
.btn-add-cart { background: #28a745; color: #fff; width: 100%; font-size: 18px; padding: 16px; margin-top: 16px; }
.final-summary { margin-top: 20px; background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 20px; }
#full-summary p { margin: 6px 0; border-bottom: 1px solid #f0f0f0; padding-bottom: 6px; }
</style>

{% schema %}
{
  "name": "Product Configurator",
  "settings": [
    {
      "type": "checkbox",
      "id": "quick_ship",
      "label": "Enable Quick Ship",
      "default": false
    },
    {
      "type": "number",
      "id": "quick_ship_days",
      "label": "Quick Ship Days",
      "default": 10
    },
    {
      "type": "text",
      "id": "standard_lead_time",
      "label": "Standard Lead Time (weeks)",
      "default": "4-6"
    }
  ],
  "presets": [
    {
      "name": "Product Configurator"
    }
  ]
}
{% endschema %}